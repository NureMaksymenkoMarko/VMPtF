Основні маршрути server.js
app.get('/api/tasks', (req, res) => {
    res.json(tasks);
});

app.get('/api/tasks/:id', (req, res) => {
    const taskId = Number(req.params.id);
    const task = tasks.find(item => item.id === taskId);

    if (!task) {
        return res.status(404).json({ message: 'Задачу не знайдено' });
    }

    res.json(task);
});

app.post('/api/tasks', (req, res) => {
    const { title, description, status } = req.body;
    const newTask = { id: nextId++, title, description, status };
    tasks.push(newTask);
    res.status(201).json(newTask);
});

app.put('/api/tasks/:id', (req, res) => {
    const taskId = Number(req.params.id);
    const { title, description, status } = req.body;
    const task = tasks.find(item => item.id === taskId);
    task.title = title;
    task.description = description;
    task.status = status;
    res.json(task);
});

app.delete('/api/tasks/:id', (req, res) => {
    const taskId = Number(req.params.id);
    tasks = tasks.filter(item => item.id !== taskId);
    res.json({ message: 'Задачу видалено' });
});
Основна логіка React-фронтенду
function loadTasks() {
    fetch('/api/tasks')
        .then(response => response.json())
        .then(data => setTasks(data))
        .catch(error => console.log('Помилка завантаження задач:', error));
}

function saveTask(event) {
    event.preventDefault();
    const url = editingId ? '/api/tasks/' + editingId : '/api/tasks';
    const method = editingId ? 'PUT' : 'POST';

    fetch(url, {
        method: method,
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(form)
    })
        .then(response => response.json())
        .then(() => {
            clearForm();
            loadTasks();
        });
}

function showDetails(id) {
    fetch('/api/tasks/' + id)
        .then(response => response.json())
        .then(data => setSelectedTask(data));
}
2.4 Висновки
     У ході виконання лабораторної роботи №2 було створено веб-додаток для управління задачами. Серверна частина була реалізована на Node.js з використанням Express, а клієнтська частина — за допомогою React. На першому рівні було реалізовано отримання та відображення списку задач із серверного маршруту GET /api/tasks.
     На другому рівні функціональність застосунку було розширено можливістю додавання, редагування та видалення задач, а також перегляду деталей конкретної задачі. Для цього були реалізовані маршрути POST, PUT, DELETE і GET за ідентифікатором, а на клієнтській стороні створено відповідні функції для взаємодії із сервером.
     У результаті виконання роботи було закріплено практичні навички створення серверного застосунку на Node.js, використання Express для маршрутизації, роботи з JSON-даними, обробки HTTP-запитів і створення динамічного інтерфейсу за допомогою React.
